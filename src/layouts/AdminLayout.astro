---
import '../styles/global.css';
import RestaurantSwitcher from '../components/RestaurantSwitcher.svelte';

export interface Props {
	title: string;
    currentPath: string;
}

const { title, currentPath } = Astro.props;

const menuItems = [
    { name: 'Dashboard', path: '/admin', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
    { name: 'Calendario', path: '/admin/calendar', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
    { name: 'Planificador', path: '/admin/planner', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01' },
    { name: 'Eventos', path: '/admin/events', icon: 'M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z' },
    { name: 'Lista de espera', path: '/admin/waitlist', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z' },
    { name: 'Turnos', path: '/admin/shifts', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
    { name: 'Configuración', path: '/admin/settings', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z' },
    { name: 'Salas', path: '/admin/rooms', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
    { name: 'Emails', path: '/admin/emails', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' }
];
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Admin Panel</title>
		<!-- Script para prevenir flashes en modo oscuro -->
		<script is:inline>
			if (
				localStorage.getItem('admin_theme') === 'dark' ||
				(!('admin_theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)
			) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="h-screen bg-[#f8f9fc] dark:bg-slate-900 flex overflow-hidden transition-colors duration-300">

		<!-- Toast Container (global) -->
		<div class="toast-container" id="toast-container"></div>

		<!-- Sidebar -->
		<aside class="w-64 bg-white dark:bg-slate-800 border-r border-gray-100 dark:border-slate-700 flex flex-col hidden md:flex shadow-sm h-full transition-colors duration-300">
			<!-- Logo -->
			<div class="h-16 flex items-center px-5 border-b border-gray-100 dark:border-slate-700 bg-brand text-white gap-3 shrink-0">
				<img src="/assets/logo-pequeno.png" class="w-8 h-8 rounded-full bg-white p-1 shadow-sm" alt="Logo" />
				<span class="font-bold text-base tracking-tight">Admin Panel</span>
			</div>
			
			<!-- Nav -->
			<nav class="flex-1 py-5 px-3 space-y-0.5 overflow-y-auto">
				{menuItems.map(item => {
                    const isActive = currentPath === item.path || (item.path !== '/admin' && currentPath.startsWith(item.path));
                    const isWaitlist = item.path === '/admin/waitlist';
                    return (
					<a href={item.path} class={`nav-item ${isActive ? 'active' : ''}`}>
						<svg class="w-[18px] h-[18px] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
						</svg>
						<span>{item.name}</span>
						
						{isWaitlist ? (
							<div class="ml-auto flex items-center gap-1.5">
								<span id="waitlist-badge" class="bg-amber-500 text-white text-[10px] font-extrabold px-1.5 py-0.5 rounded-full hidden leading-none min-w-[18px] text-center shadow-sm">0</span>
								{isActive && (
									<span class="w-1.5 h-1.5 rounded-full bg-brand shrink-0"></span>
								)}
							</div>
						) : (
							isActive && (
								<span class="ml-auto w-1.5 h-1.5 rounded-full bg-brand shrink-0"></span>
							)
						)}
					</a>
                );})}
			</nav>

			<!-- Footer con Información de Admin y Toggle de Modo Oscuro -->
            <div class="border-t border-gray-100 dark:border-slate-700 bg-white dark:bg-slate-800 shrink-0 transition-colors duration-300">
                <div class="p-4 flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center font-bold text-xs shrink-0">
                            AD
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm font-semibold text-gray-800 dark:text-slate-200 truncate">Administrador</p>
                            <p class="text-xs text-gray-400 dark:text-slate-400">Panel de control</p>
                        </div>
                    </div>
                    <!-- Botón de Modo Oscuro -->
                    <button id="theme-toggle" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition text-gray-500 dark:text-slate-400" title="Cambiar tema">
                        <!-- Sol (se muestra en dark mode) -->
                        <svg id="theme-toggle-light-icon" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                        </svg>
                        <!-- Luna (se muestra en light mode) -->
                        <svg id="theme-toggle-dark-icon" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                        </svg>
                    </button>
                </div>
                <!-- Selector de Restaurante -->
                <RestaurantSwitcher client:only="svelte" />
            </div>
		</aside>

		<!-- Main Content -->
		<div class="flex-1 flex flex-col h-screen overflow-hidden">
            <!-- Mobile Header -->
            <header class="md:hidden h-14 bg-brand dark:bg-slate-900 text-white flex items-center px-4 justify-between shadow-sm border-b dark:border-slate-800 transition-colors duration-300">
                <div class="flex items-center gap-2">
                    <img src="/assets/logo-pequeno.png" class="w-7 h-7 rounded-full bg-white p-1" alt="Logo" />
                    <span class="font-bold text-sm tracking-tight">Admin Panel</span>
                </div>
                <div class="flex items-center gap-1">
                    <!-- Botón de Modo Oscuro Móvil -->
                    <button id="theme-toggle-mobile" class="p-2 rounded-lg hover:bg-white/10 transition" title="Cambiar tema">
                        <svg id="theme-toggle-light-icon-mobile" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                        </svg>
                        <svg id="theme-toggle-dark-icon-mobile" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                        </svg>
                    </button>
                    <!-- Menú móvil -->
                    <button class="p-2 rounded-lg hover:bg-white/10 transition">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </header>

			<main class="flex-1 overflow-y-auto p-4 md:p-8 bg-[#f8f9fc] dark:bg-slate-900 transition-colors duration-300">
				<slot />
			</main>
		</div>

		<!-- Toast Script (Global) -->
		<script is:inline>
			window.showToast = function(message, type = 'success', duration = 3500) {
				const container = document.getElementById('toast-container');
				if (!container) return;

				const icons = {
					success: '<svg style="width:18px;height:18px;shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>',
					error: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>',
					info: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01"/></svg>',
					warning: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>',
				};

				const toast = document.createElement('div');
				toast.className = `toast ${type}`;
				toast.innerHTML = `${icons[type] || ''}<span>${message}</span>`;
				container.appendChild(toast);

				setTimeout(() => {
					toast.classList.add('hide');
					setTimeout(() => toast.remove(), 250);
				}, duration);
			};
		</script>

		<!-- Script reactivo para la notificación de Lista de Espera -->
		<script>
			import { supabase } from '../lib/supabase';

			async function updateWaitlistBadge() {
				const restaurantId = localStorage.getItem('admin_restaurant_id') || '00000000-0000-0000-0000-000000000000';
				try {
					const { count, error } = await supabase
						.from('waitlist')
						.select('*', { count: 'exact', head: true })
						.eq('restaurant_id', restaurantId)
						.eq('estado', 'esperando');

					if (error) throw error;

					const badge = document.getElementById('waitlist-badge');
					if (badge) {
						if (count !== null && count > 0) {
							badge.textContent = count.toString();
							badge.classList.remove('hidden');
						} else {
							badge.classList.add('hidden');
						}
					}
				} catch (err) {
					console.error('Error al actualizar contador de lista de espera:', err);
				}
			}

			// Carga inicial al cargar la página
			updateWaitlistBadge();

			// Escucha de cambios de restaurante
			window.addEventListener('storage', (e) => {
				if (e.key === 'admin_restaurant_id') {
					updateWaitlistBadge();
				}
			});

			// Actualización periódica en segundo plano para redundancia (4s)
			setInterval(updateWaitlistBadge, 4000);

			// Suscripción en Tiempo Real (Realtime) a cambios en la tabla waitlist
			try {
				supabase
					.channel('waitlist_badge_realtime')
					.on(
						'postgres_changes',
						{
							event: '*',
							schema: 'public',
							table: 'waitlist'
						},
						() => {
							updateWaitlistBadge();
						}
					)
					.subscribe();
			} catch (realtimeErr) {
				console.warn('Realtime subscription not supported or blocked:', realtimeErr);
			}
		</script>

        <!-- Script de Modo Oscuro (Toggle) -->
        <script is:inline>
            function setupThemeToggle() {
                const toggleBtn = document.getElementById('theme-toggle');
                const toggleBtnMobile = document.getElementById('theme-toggle-mobile');
                
                const lightIcon = document.getElementById('theme-toggle-light-icon');
                const darkIcon = document.getElementById('theme-toggle-dark-icon');
                
                const lightIconMobile = document.getElementById('theme-toggle-light-icon-mobile');
                const darkIconMobile = document.getElementById('theme-toggle-dark-icon-mobile');

                function updateIcons() {
                    const isDark = document.documentElement.classList.contains('dark');
                    if (isDark) {
                        lightIcon?.classList.remove('hidden');
                        darkIcon?.classList.add('hidden');
                        lightIconMobile?.classList.remove('hidden');
                        darkIconMobile?.classList.add('hidden');
                    } else {
                        lightIcon?.classList.add('hidden');
                        darkIcon?.classList.remove('hidden');
                        lightIconMobile?.classList.add('hidden');
                        darkIconMobile?.classList.remove('hidden');
                    }
                }

                function toggleTheme() {
                    const isDark = document.documentElement.classList.contains('dark');
                    if (isDark) {
                        document.documentElement.classList.remove('dark');
                        localStorage.setItem('admin_theme', 'light');
                    } else {
                        document.documentElement.classList.add('dark');
                        localStorage.setItem('admin_theme', 'dark');
                    }
                    updateIcons();
                }

                toggleBtn?.addEventListener('click', toggleTheme);
                toggleBtnMobile?.addEventListener('click', toggleTheme);
                
                updateIcons();
            }

            // Iniciar setup
            setupThemeToggle();
        </script>
	</body>
</html>
