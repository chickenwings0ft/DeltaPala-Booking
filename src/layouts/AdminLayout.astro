---
import '../styles/global.css';
import RestaurantSwitcher from '../components/RestaurantSwitcher.svelte';

export interface Props {
	title: string;
    currentPath: string;
}

const { title, currentPath } = Astro.props;

const menuItems = [
    { name: 'Dashboard', path: '/admin', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
    { name: 'Calendario', path: '/admin/calendar', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
    { name: 'Eventos', path: '/admin/events', icon: 'M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z' },
    { name: 'Lista de espera', path: '/admin/waitlist', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
    { name: 'Turnos', path: '/admin/shifts', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
    { name: 'Configuración', path: '/admin/settings', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z' },
    { name: 'Salas', path: '/admin/rooms', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
    { name: 'Emails', path: '/admin/emails', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' }
];
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Admin Panel</title>
	</head>
	<body class="min-h-screen bg-[#f8f9fc] flex">

		<!-- Toast Container (global) -->
		<div class="toast-container" id="toast-container"></div>

		<!-- Sidebar -->
		<aside class="w-64 bg-white border-r border-gray-100 flex flex-col hidden md:flex shadow-sm" style="min-height:100vh;">
			<!-- Logo -->
			<div class="h-16 flex items-center justify-center px-4 border-b border-white/20 bg-brand">
				<img src="/assets/logo-grande.png" class="h-8 w-auto object-contain" alt="Logo" />
			</div>
			
			<!-- Nav -->
			<nav class="flex-1 py-5 px-3 space-y-0.5">
				{menuItems.map(item => {
                    const isActive = currentPath === item.path || (item.path !== '/admin' && currentPath.startsWith(item.path));
                    return (
					<a href={item.path} class={`nav-item ${isActive ? 'active' : ''}`}>
						<svg class="w-[18px] h-[18px] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
						</svg>
						<span>{item.name}</span>
						{isActive && (
							<span class="ml-auto w-1.5 h-1.5 rounded-full bg-brand"></span>
						)}
					</a>
                );})}
			</nav>

			<!-- Footer -->
            <div class="border-t border-gray-100">
                <div class="p-4 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center font-bold text-xs shrink-0">
                        AD
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-gray-800 truncate">Administrador</p>
                        <p class="text-xs text-gray-400">Panel de control</p>
                    </div>
                </div>
                <!-- Selector de Restaurante -->
                <RestaurantSwitcher client:only="svelte" />
            </div>
		</aside>

		<!-- Main Content -->
		<div class="flex-1 flex flex-col min-h-screen overflow-hidden">
            <!-- Mobile Header -->
            <header class="md:hidden h-14 bg-brand text-white flex items-center px-4 justify-between shadow-sm">
                <div class="flex items-center">
                    <img src="/assets/logo-grande.png" class="h-7 w-auto object-contain" alt="Logo" />
                </div>
                <button class="p-2 rounded-lg hover:bg-white/10 transition">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </header>

			<main class="flex-1 overflow-y-auto p-4 md:p-8">
				<slot />
			</main>
		</div>

		<!-- Toast Script (Global) -->
		<script is:inline>
			window.showToast = function(message, type = 'success', duration = 3500) {
				const container = document.getElementById('toast-container');
				if (!container) return;

				const icons = {
					success: '<svg style="width:18px;height:18px;shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>',
					error: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>',
					info: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01"/></svg>',
					warning: '<svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>',
				};

				const toast = document.createElement('div');
				toast.className = `toast ${type}`;
				toast.innerHTML = `${icons[type] || ''}<span>${message}</span>`;
				container.appendChild(toast);

				setTimeout(() => {
					toast.classList.add('hide');
					setTimeout(() => toast.remove(), 250);
				}, duration);
			};
		</script>
	</body>
</html>
