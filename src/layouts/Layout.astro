---
import '../styles/global.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="bg-[#004aad] text-white h-28 relative flex justify-center shadow-md">
			<div class="absolute -bottom-10 bg-white p-1 rounded-full shadow-lg h-24 w-24 flex items-center justify-center border-4 border-gray-100 overflow-hidden">
				<img src="/assets/logo-pequeno.png" alt="Logo de la marca" class="w-full h-full object-contain rounded-full" />
			</div>
		</header>
		<main class="flex-grow pt-14 px-4 pb-8">
			<slot />
		</main>
	</body>
</html>
