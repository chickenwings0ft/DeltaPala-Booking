---
import AdminLayout from '../../layouts/AdminLayout.astro';
import CalendarView from '../../components/CalendarView.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';
---

<AdminLayout title="Calendario de Reservas" currentPath="/admin/calendar">
	<div class="max-w-6xl mx-auto">
		<div class="mb-6">
			<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Calendario de Disponibilidad</h1>
			<p class="text-gray-500 mt-1">Vista visual de ocupación mensual y gestión de excepciones de calendario.</p>
		</div>

        <CalendarView client:only="svelte" restaurantId={RESTAURANT_ID} />
	</div>
</AdminLayout>
