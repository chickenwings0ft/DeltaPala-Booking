---
import AdminLayout from '../../layouts/AdminLayout.astro';
import EmailEditor from '../../components/EmailEditor.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';
---

<AdminLayout title="Plantillas de Email" currentPath="/admin/emails">
	<div class="max-w-6xl mx-auto">
		<div class="mb-6">
			<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Plantillas de Email</h1>
			<p class="text-gray-500 mt-1">Personaliza los mensajes automáticos que se envían a tus clientes.</p>
		</div>

        <EmailEditor client:only="svelte" restaurantId={RESTAURANT_ID} />
	</div>
</AdminLayout>
