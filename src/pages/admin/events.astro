---
import AdminLayout from '../../layouts/AdminLayout.astro';
import EventManager from '../../components/EventManager.svelte';

// ID fijo de restaurante (MVP)
const RESTAURANT_ID = '11111111-1111-1111-1111-111111111111';
---

<AdminLayout title="Gestión de Eventos" currentPath="/admin/events">
	<div class="max-w-6xl mx-auto w-full px-4 md:px-0">
		<EventManager client:only="svelte" restaurantId={RESTAURANT_ID} />
	</div>
</AdminLayout>
