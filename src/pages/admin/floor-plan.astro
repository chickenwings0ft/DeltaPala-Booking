---
import AdminLayout from '../../layouts/AdminLayout.astro';
import FloorPlanEditor from '../../components/FloorPlanEditor.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';

// Fecha seleccionada por defecto (hoy)
const today = new Date().toISOString().split('T')[0];
---

<AdminLayout title="Plano de Salas" currentPath="/admin/floor-plan">
	<div class="max-w-6xl mx-auto w-full px-4 md:px-0 h-[calc(100vh-8rem)]">
		<div class="mb-6 flex justify-between items-end">
			<div>
				<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Editor de Plano</h1>
				<p class="text-gray-500 mt-1">Diseña la distribución de tus mesas y visualiza su ocupación en tiempo real.</p>
			</div>
            <div class="flex items-center gap-2">
                <label class="text-sm font-medium text-gray-700">Ver ocupación para el día:</label>
                <!-- En un entorno real esto filtraría reactivamente desde el componente, aquí pasamos hoy -->
                <input type="date" value={today} disabled class="border border-gray-300 rounded-lg p-2 text-sm bg-gray-50 text-gray-500 cursor-not-allowed" title="En la vista completa esto será dinámico" />
            </div>
		</div>

        <FloorPlanEditor client:only="svelte" restaurantId={RESTAURANT_ID} selectedDate={today} viewModeOnly={false} />
	</div>
</AdminLayout>
