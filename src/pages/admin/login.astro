---
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Admin Panel</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }
    </style>
</head>
<body class="h-screen w-full flex items-center justify-center bg-gray-50 relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[50%] bg-brand/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[30%] h-[40%] bg-blue-400/10 rounded-full blur-[100px]"></div>
    </div>

    <!-- Login Container -->
    <div class="glass-panel w-full max-w-md p-8 md:p-10 rounded-2xl relative z-10 m-4">
        <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 bg-brand rounded-2xl shadow-lg flex items-center justify-center mb-4 text-white">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Acceso Admin</h1>
            <p class="text-sm text-gray-500 mt-2 text-center">Inicia sesión para gestionar el sistema de reservas y eventos.</p>
        </div>

        <form id="login-form" class="space-y-5">
            <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Correo Electrónico</label>
                <input 
                    type="email" 
                    id="email" 
                    required 
                    class="w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none"
                    placeholder="admin@restaurante.com"
                >
            </div>
            <div>
                <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Contraseña</label>
                <input 
                    type="password" 
                    id="password" 
                    required 
                    class="w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none"
                    placeholder="••••••••"
                >
            </div>

            <div id="error-message" class="hidden bg-red-50 text-red-600 text-sm p-3 rounded-lg border border-red-100 flex items-start gap-2">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span id="error-text">Credenciales incorrectas. Inténtalo de nuevo.</span>
            </div>

            <button 
                type="submit" 
                id="submit-btn"
                class="w-full bg-brand hover:bg-brand/90 text-white font-bold py-3 px-4 rounded-xl shadow-md hover:shadow-lg transition-all flex justify-center items-center gap-2"
            >
                <span>Entrar al Panel</span>
                <svg id="loading-spinner" class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </form>
    </div>

    <script>
        import { supabase } from '../../lib/supabase';

        const form = document.getElementById('login-form') as HTMLFormElement;
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const errorMessage = document.getElementById('error-message');
        const errorText = document.getElementById('error-text');
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const loadingSpinner = document.getElementById('loading-spinner');

        // Redirigir si ya está logueado
        supabase.auth.getSession().then(({ data: { session } }) => {
            if (session) {
                window.location.href = '/admin';
            }
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // UI State loading
            errorMessage?.classList.add('hidden');
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
            loadingSpinner?.classList.remove('hidden');

            try {
                // BYPASS MODO DEMO PARA TESTEO UI MVP
                if (emailInput.value === 'admin@demo.com' && passwordInput.value === 'admin123') {
                    localStorage.setItem('demo_mode', 'true');
                    window.location.href = '/admin';
                    return;
                }

                const { data, error } = await supabase.auth.signInWithPassword({
                    email: emailInput.value,
                    password: passwordInput.value,
                });

                if (error) {
                    throw error;
                }

                if (data.session) {
                    // Login exitoso
                    window.location.href = '/admin';
                }
            } catch (err: any) {
                console.error('Login error:', err);
                if (errorMessage && errorText) {
                    errorText.textContent = err.message === 'Invalid login credentials' 
                        ? 'Correo o contraseña incorrectos.' 
                        : 'Ocurrió un error al intentar iniciar sesión.';
                    errorMessage.classList.remove('hidden');
                }
            } finally {
                // UI State restore
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
                loadingSpinner?.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
