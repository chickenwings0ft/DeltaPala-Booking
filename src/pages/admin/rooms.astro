---
import AdminLayout from '../../layouts/AdminLayout.astro';
import RoomManager from '../../components/RoomManager.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';
---

<AdminLayout title="Gestión de Salas" currentPath="/admin/rooms">
	<div class="max-w-6xl mx-auto w-full px-4 md:px-0">
		<div class="mb-6">
			<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Salas y Espacios</h1>
			<p class="text-gray-500 mt-1">Configura las zonas de tu restaurante y su capacidad máxima.</p>
		</div>

        <RoomManager client:only="svelte" restaurantId={RESTAURANT_ID} />
	</div>
</AdminLayout>
