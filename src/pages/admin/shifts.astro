---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ShiftManager from '../../components/ShiftManager.svelte';
import OpeningHoursConfig from '../../components/OpeningHoursConfig.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';
---

<AdminLayout title="Turnos y Aforos" currentPath="/admin/shifts">
	<div class="max-w-6xl mx-auto w-full px-4 md:px-0 space-y-8">
		<div>
			<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Gestión de Turnos</h1>
			<p class="text-gray-500 mt-1">Configura horarios, duración de reservas y aforos dinámicos.</p>
		</div>

        <OpeningHoursConfig client:only="svelte" restaurantId={RESTAURANT_ID} />
        <ShiftManager client:only="svelte" restaurantId={RESTAURANT_ID} />
	</div>
</AdminLayout>
