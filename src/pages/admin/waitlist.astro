---
import AdminLayout from '../../layouts/AdminLayout.astro';
import WaitlistManager from '../../components/WaitlistManager.svelte';

// ID de restaurante fijo para el MVP
const RESTAURANT_ID = '00000000-0000-0000-0000-000000000000';
---

<AdminLayout title="Lista de Espera" currentPath="/admin/waitlist">
	<div class="max-w-6xl mx-auto w-full px-4 md:px-0">
		<div class="mb-6">
			<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Lista de Espera</h1>
			<p class="text-gray-500 mt-1">Gestión de clientes interesados en fechas sin disponibilidad.</p>
		</div>

		<div class="space-y-6">
            <WaitlistManager client:only="svelte" restaurantId={RESTAURANT_ID} />
        </div>
	</div>
</AdminLayout>
